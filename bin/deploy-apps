#!/usr/bin/env bash
# deploy-apps — build every Tauri desktop app's RELEASE .app bundle, install it to /Applications,
# and upload a .dmg to a GitHub release at the app's version. Complements bin/release-all (which
# handles crate/formula TAG bumps for the CLI tools); this handles the GUI-app build+install+publish.
#
# Builds with `--bundles app` ONLY, so Tauri's interactive dmg bundler (which mounts the volume and
# runs an osascript Finder-window arrangement — the "drag to Applications" popup) never runs. The
# .app is installed to /Applications with cp -R (no dragging). The .dmg for GitHub is produced
# HEADLESSLY with hdiutil from a staging folder (.app + /Applications symlink) — no Finder window.
#
# Apps are discovered dynamically: every tauri.conf.json under a top-level submodule (new apps are
# picked up automatically). Build dir is <app>/app if it has package.json, else <app>. Release tag
# is v<version> from tauri.conf.json's "version".
#
# Usage:
#   ./bin/deploy-apps                       # build + install + upload every app
#   ./bin/deploy-apps --only=zthrottle,zcite
#   ./bin/deploy-apps --no-install          # build + upload, don't touch /Applications
#   ./bin/deploy-apps --no-upload           # build + install, no GitHub release / dmg
#   ./bin/deploy-apps --no-build            # install/upload already-built .app bundles only
set -uo pipefail

META_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
# Build logs go to a cache dir, NEVER inside the repo (a *.deploy.log per app in META_ROOT
# would pollute the working tree and show up in git status).
LOGDIR="${HOME}/.cache/menke-ship"; mkdir -p "$LOGDIR"
ONLY=""; DO_BUILD=1; DO_INSTALL=1; DO_UPLOAD=1
for a in "$@"; do
  case "$a" in
    --only=*)     ONLY="${a#--only=}" ;;
    --no-build)   DO_BUILD=0 ;;
    --no-install) DO_INSTALL=0 ;;
    --no-upload)  DO_UPLOAD=0 ;;
    *) echo "unknown arg: $a" >&2; exit 2 ;;
  esac
done

# Discover Tauri apps: a tauri.conf.json directly under a top-level dir (not nested in crates/ or libs/).
mapfile -t APPS < <(find "$META_ROOT" -maxdepth 4 -name tauri.conf.json 2>/dev/null \
  | grep -viE 'node_modules|/crates/.*/crates|/libs/' \
  | perl -pe "s#^\Q$META_ROOT\E/##; s#/(app/)?src-tauri/tauri\.conf\.json##" | sort -u)

# Make a distributable dmg from a .app WITHOUT any Finder popup: stage app + Applications symlink,
# then hdiutil create (compressed UDZO). Prints the dmg path on success. hdiutil's auto-sizing
# underestimates when the .app carries a sparse image (e.g. a bundled VM rootfs.img), so on failure
# retry with an explicit size from the app's apparent bytes; UDZO compresses the zero blocks away.
make_dmg() { # $1=appbundle  $2=out.dmg  $3=volname
  local stage; stage="$(mktemp -d)"
  cp -R "$1" "$stage/" && ln -s /Applications "$stage/Applications"
  rm -f "$2"
  if hdiutil create -volname "$3" -srcfolder "$stage" -ov -format UDZO -quiet "$2" 2>/dev/null; then
    echo "$2"
  else
    local apparent size_m
    apparent=$(find "$1" -type f -print0 | xargs -0 stat -f %z 2>/dev/null | awk '{s+=$1} END{print s+0}')
    size_m=$(( apparent / 1048576 + 200 ))
    rm -f "$2"
    hdiutil create -volname "$3" -srcfolder "$stage" -ov -format UDZO -size "${size_m}m" -quiet "$2" 2>/dev/null && echo "$2"
  fi
  rm -rf "$stage"
  # Report success ONLY if the dmg actually exists — otherwise a missing artifact (e.g. hdiutil
  # ran out of disk on a large bundle) would still be handed to `gh`, failing the whole upload
  # and dropping the pkg too.
  [ -s "$2" ]
}

# Make a flat installer .pkg from a .app (installs into /Applications). Headless, no UI.
make_pkg() { # $1=appbundle  $2=out.pkg  $3=identifier  $4=version
  local stage; stage="$(mktemp -d)"
  cp -R "$1" "$stage/"
  rm -f "$2"
  pkgbuild --root "$stage" --install-location /Applications --identifier "$3" --version "$4" "$2" >/dev/null 2>&1 && echo "$2"
  rm -rf "$stage"
  [ -s "$2" ]
}

summary=""
for app in "${APPS[@]}"; do
  [ -n "$ONLY" ] && { case ",$ONLY," in *,"$app",*) : ;; *) continue ;; esac; }
  d="$META_ROOT/$app"
  [ -f "$d/app/package.json" ] && bd="$d/app" || bd="$d"
  log="$LOGDIR/$app.deploy.log"

  if [ "$DO_BUILD" = 1 ]; then
    echo "=== build $app ($bd) — .app only, no dmg popup ==="
    # Default builder is `pnpm tauri build --bundles app`. Apps that can't use it (e.g. traderview
    # needs cargo-tauri + frontend-dist isolation) ship an executable scripts/deploy-build.sh that
    # produces the .app under release/bundle/macos; use it when present.
    if [ -x "$bd/scripts/deploy-build.sh" ]; then
      buildcmd=( ./scripts/deploy-build.sh )
    else
      buildcmd=( pnpm tauri build --bundles app )
    fi
    if ! ( cd "$bd" && "${buildcmd[@]}" ) >"$log" 2>&1; then
      echo "$app: BUILD FAILED (see $log)"; summary+="  x $app build-failed"$'\n'; continue
    fi
  fi

  appbundle=$(find "$d" -path '*/release/bundle/macos/*.app' -type d 2>/dev/null | head -1)
  [ -z "$appbundle" ] && { echo "$app: no .app bundle"; summary+="  x $app no-.app"$'\n'; continue; }
  name=$(basename "$appbundle")

  installed=""
  if [ "$DO_INSTALL" = 1 ]; then
    dst="/Applications/$name"
    if rm -rf "$dst" 2>/dev/null && cp -R "$appbundle" "$dst" 2>/dev/null; then
      echo "$app: installed $dst"; installed=" installed"
    elif sudo -n rm -rf "$dst" 2>/dev/null && sudo -n cp -R "$appbundle" "$dst" 2>/dev/null; then
      # existing bundle owned by another user (e.g. root/other account) — elevate
      echo "$app: installed $dst (sudo)"; installed=" installed"
    else
      echo "$app: INSTALL FAILED (perms on $dst)"; summary+="  x $app install-failed"$'\n'
    fi
  fi

  did_upload=""
  if [ "$DO_UPLOAD" = 1 ]; then
    cfg=""
    for c in "$d"/app/src-tauri/tauri.conf.json "$d"/src-tauri/tauri.conf.json; do
      [ -f "$c" ] && { cfg="$c"; break; }
    done
    # Tauri allows "version" to be a path to a package.json (e.g. "../package.json"); resolve it.
    ver=$(node -e "const fs=require('fs'),p=require('path'),c=process.argv[1];let v='';try{v=JSON.parse(fs.readFileSync(c,'utf8')).version||''}catch(e){}if(v&&(v.endsWith('.json')||v.includes('/'))){try{v=JSON.parse(fs.readFileSync(p.resolve(p.dirname(c),v),'utf8')).version||''}catch(e){v=''}}console.log(v)" "$cfg" 2>/dev/null)
    id=$(node -e "try{console.log(JSON.parse(require('fs').readFileSync(process.argv[1],'utf8')).identifier||'')}catch(e){}" "$cfg" 2>/dev/null)
    tag="v${ver:-0.0.0}"; repo="MenkeTechnologies/$app"
    dmg="$d/${app}_${ver:-0.0.0}_aarch64.dmg"
    pkg="$d/${app}_${ver:-0.0.0}_aarch64.pkg"
    # build both installer artifacts (dmg for drag-install, pkg for flat-installer)
    assets=()
    make_dmg "$appbundle" "$dmg" "$app" >/dev/null && assets+=("$dmg")
    make_pkg "$appbundle" "$pkg" "${id:-com.menketechnologies.$app}" "${ver:-0.0.0}" >/dev/null && assets+=("$pkg")
    if [ "${#assets[@]}" -gt 0 ]; then
      if gh release view "$tag" --repo "$repo" >/dev/null 2>&1; then
        gh release upload "$tag" "${assets[@]}" --clobber --repo "$repo" >/dev/null 2>&1 && { echo "$app: uploaded $tag (dmg+pkg)"; did_upload=" uploaded"; }
      else
        gh release create "$tag" "${assets[@]}" --repo "$repo" --title "$app $tag" \
          --notes "$app $tag — macOS Apple silicon. .dmg: drag to Applications. .pkg: double-click to install. Unsigned: first launch right-click -> Open." >/dev/null 2>&1 \
          && { echo "$app: created release $tag (dmg+pkg)"; did_upload=" uploaded"; }
      fi
      rm -f "$dmg" "$pkg"
    else
      echo "$app: installer build FAILED"
    fi
  fi
  summary+="  + $app${installed}${did_upload}"$'\n'
done

echo ""; echo "=== deploy summary ==="; printf "%s" "$summary"
