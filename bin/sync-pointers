#!/usr/bin/env sh
# sync-pointers — stage every submodule pointer bump and create a single
# commit.  Run after `pull-all` (or any time submodules moved forward).
#
# Usage:  ./bin/sync-pointers [optional commit message]
set -eu

META_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$META_ROOT"

if [ ! -f .gitmodules ]; then
  echo "sync-pointers: $(pwd) has no .gitmodules — wrong directory?" >&2
  exit 1
fi

MSG="${1:-submodules: pointer sync ($(date -u +%Y-%m-%d))}"

# Stage only submodule pointer changes (avoid sweeping in stray edits).
# Use `git submodule status` — its '+' prefix means "checked-out HEAD differs from
# the recorded pointer", which is exactly a pending bump. Do NOT use
# `git status --porcelain`: it recurses into each submodule working tree to check
# for dirtiness and aborts on nested *symlinked* submodules (e.g. zpwr-fx's
# libs/JUCE → "expected submodule path 'libs/JUCE' not to be a symbolic link").
CHANGED=$(git submodule status | awk '/^\+/ { print $2 }')

if [ -z "$CHANGED" ]; then
  echo "sync-pointers: no submodule pointer changes to commit"
  exit 0
fi

echo "==> staging:"
# CHANGED is a newline-separated list of submodule paths; word-split is intentional.
# shellcheck disable=SC2086
printf '    %s\n' $CHANGED

# shellcheck disable=SC2086
for path in $CHANGED; do
  git add "$path"
done

git commit -m "$MSG"

echo ""
echo "==> done.  Push with:  git push"
