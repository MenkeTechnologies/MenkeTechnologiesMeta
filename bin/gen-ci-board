#!/usr/bin/env bash
# gen-ci-board — regenerate the [0x02] CI STATUS BOARD tables in README.md.
#
# Tier grouping comes from the [0x01] SUBMODULE MAP tables in README.md;
# each repo's active workflows and default branch come live from the GitHub
# API (no baked-in data). CI badges pin the repo's default branch; release
# workflows (tag-triggered) get an unpinned badge in the Release column.
#
# Usage:
#   bin/gen-ci-board               # print board markdown to stdout
#   bin/gen-ci-board --in-place    # splice tables into README.md
#
# Requires: gh (authenticated), bash 4.4+.
set -euo pipefail
cd "$(dirname "$0")/.." || exit 1

base=https://github.com/MenkeTechnologies

gen() {
    local line r br priv ci relb verb cf rf w tier
    local -a wf extras
    tier=""
    printf '\n| Tier | Repo | CI | Release | Version |\n|---|---|---|---|---|\n'
    # Source of truth is the [0x01] SUBMODULE MAP section only — the board's
    # own table also matches these patterns, so never grep the whole file.
    while IFS= read -r line; do
        if [[ $line == "### Tier"* ]]; then
            # "### Tier 4 — Zsh ecosystem plugins (28)" -> "4 — Zsh ecosystem plugins"
            tier=${line#\#\#\# Tier }
            tier=${tier% (*}
            continue
        fi
        r=${line#*[\`}
        r=${r%%\`*}
        [[ $r == */* ]] && continue
        IFS=$'\t' read -r br priv < <(gh api "repos/MenkeTechnologies/$r" \
            --jq '[.default_branch, .private] | @tsv' 2>/dev/null) || { br=main; priv=false; }
        [[ -z $br ]] && br=main
        # Private repos have no public Actions runs, badges, or tags — shields.io
        # and the GitHub badge endpoint both render "repo not found". Emit em
        # dashes so the board stays clean instead of showing broken images.
        if [[ $priv == true ]]; then
            printf '| %s | [`%s`](%s) | — | — | — |\n' "$tier" "$r" "$base/$r"
            continue
        fi
        mapfile -t wf < <(gh api "repos/MenkeTechnologies/$r/actions/workflows" \
            --jq '.workflows[] | select(.state=="active") | .path' 2>/dev/null |
            grep -v dynamic | sed 's|.github/workflows/||' || true)
        cf=""
        rf=""
        extras=()
        for w in "${wf[@]}"; do
            [[ -z $w ]] && continue
            case $w in
                release*.yml | release*.yaml) rf=$w ;;
                ci.yml | test.yaml | test.yml) cf=$w ;;
                *) extras+=("$w") ;;
            esac
        done
        # No conventional CI file: promote the first leftover workflow.
        if [[ -z $cf && ${#extras[@]} -gt 0 ]]; then
            cf=${extras[0]}
            extras=("${extras[@]:1}")
        fi
        if [[ -z $cf ]]; then
            ci="—"
        else
            ci="[![CI]($base/$r/actions/workflows/$cf/badge.svg?branch=$br)]($base/$r/actions/workflows/$cf)"
            for w in "${extras[@]}"; do
                ci+=" [![${w%.y*ml}]($base/$r/actions/workflows/$w/badge.svg?branch=$br)]($base/$r/actions/workflows/$w)"
            done
        fi
        if [[ -n $rf ]]; then
            relb="[![Release]($base/$r/actions/workflows/$rf/badge.svg)]($base/$r/actions/workflows/$rf)"
        else
            relb="—"
        fi
        # Latest git tag, semver-sorted. Repos with no tags render a grey
        # "no releases" badge — same as a hand-authored row would.
        verb="[![Version](https://img.shields.io/github/v/tag/MenkeTechnologies/$r?sort=semver&label=&color=blue)]($base/$r/tags)"
        # shellcheck disable=SC2016  # backticks are literal markdown, not expansion
        printf '| %s | [`%s`](%s) | %s | %s | %s |\n' "$tier" "$r" "$base/$r" "$ci" "$relb" "$verb"
    done < <(awk '/^## \[0x01\] SUBMODULE MAP/{on=1; next} on && /^## \[/{exit} on' README.md |
        grep -E '^### Tier |^\| \[`')
    printf '\n'
}

if [[ ${1:-} == --in-place ]]; then
    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT
    gen >"$tmp"
    BOARD_FILE=$tmp perl -e '
        local $/;
        open my $f, "<", "README.md" or die; my $md = <$f>; close $f;
        open my $b, "<", $ENV{BOARD_FILE} or die; my $board = <$b>; close $b;
        my $n = ($md =~ s/(^## \[0x02\] CI STATUS BOARD\n.*?actions\/workflows`\)\.\n).*?(?=^## \[)/$1$board/ms);
        die "gen-ci-board: board section markers not found in README.md\n" unless $n == 1;
        open my $o, ">", "README.md" or die; print $o $md; close $o;
    '
    echo "gen-ci-board: README.md board refreshed"
else
    gen
fi
