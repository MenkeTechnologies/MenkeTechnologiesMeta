# Override the global `[Bb]in/` ignore — bin/ here is project source, not
# build output.
!bin/
!bin/*

# Override the global `docs/` ignore — docs/ here is the GitHub Pages
# source for menketechnologies.github.io/MenkeTechnologiesMeta/ (hud
# template + tier overview + engineering report), not build output.
!docs/
!docs/*

# macOS junk — re-ignore even under the un-ignored docs/ above
.DS_Store
docs/.DS_Store
